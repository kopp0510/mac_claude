# Telegram Bot 配置
# 從 @BotFather 獲取 Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 允許的用戶 ID（逗號分隔）
# 必填，不可為空（空白將拒絕啟動）
ALLOWED_USER_IDS=111111111,222222222

# 會話配置文件路徑（可選）
SESSIONS_CONFIG_FILE=sessions.yaml

# ⚠️ 安全提醒：
# 1. 絕對不要將真實的 Token 提交到版本控制
# 2. 確保 .env 文件在 .gitignore 中
# 3. 如果 Token 已洩露，立即在 @BotFather 重新生成
