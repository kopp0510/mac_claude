# Claude Code 會話配置範例
# 複製此文件為 sessions.yaml 並修改路徑

sessions:
  # 範例會話 1
  - name: project1
    path: /Users/username/project/project1
    tmux: claude-project1

  # 範例會話 2
  - name: project2
    path: /Users/username/project/project2
    # tmux 可選，預設為 claude-project2

  # Docker 範例 — path 必須與 docker-compose.yml 中的 volume 對齊
  # docker-compose.yml: - /Users/username/project/api:/workspace/api
  # - name: api
  #   path: /workspace/api
